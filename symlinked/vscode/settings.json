{
    "redhat.telemetry.enabled": false,
    "telemetry.telemetryLevel": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.codeActionsOnSave": {},
    "editor.copyWithSyntaxHighlighting": false,
    "editor.multiCursorModifier": "alt",
    "editor.renderWhitespace": "all",
    "editor.snippetSuggestions": "top",
    "files.autoSave": "off",
    "files.insertFinalNewline": true,
    "security.workspace.trust.untrustedFiles": "open",
    "window.openFilesInNewWindow": "off",
    "workbench.tree.indent": 20,
    "editor.fontFamily": "Iosevka",
    "todo-tree.highlights.backgroundColourScheme": [
        "red",
        "orange",
        "yellow",
        "green",
        "blue",
        "indigo",
        "violet",
        "white"
    ],
    "workbench.editor.empty.hint": "hidden",
    "explorer.confirmDelete": false,
    "glsllint.glslangValidatorArgs": "-V",
    "C_Cpp.intelliSenseEngine": "disabled",
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "go.toolsManagement.autoUpdate": true,
    "window.autoDetectColorScheme": true,
    "idf.port": "${env:ESPPORT}",
    "idf.pythonBinPath": "${env:IDF_PYTHON_ENV_PATH}/bin/python",
    "idf.showOnboardingOnInit": false,
    "extensions.ignoreRecommendations": true,
    "editor.formatOnSave": false,
    "codeium.enableCodeLens": false,
    "search.exclude": {
        "**/.mypy_cache": true
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": true,
    },
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "editor.formatOnSave": true,
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    "go.enableCodeLens": {},
    "gopls": {
        "usePlaceholders": true,
        "codelenses": {
            "gc_details": true,
            "generate": true,
            "regenerate_cgo": true,
            "tidy": true,
            "upgrade_dependency": true,
            "vendor": true
        },
        "staticcheck": true
    },
    "go.editorContextMenuCommands": {
        "fillStruct": true,
        "testFile": true,
        "testPackage": true,
        "generateTestForFile": true
    },
    "go.buildTags": "moretests,online",
    "go.testTags": "moretests,online",
    "go.lintFlags": [
        "--build-tags=moretests,online",
        "-checks",
        "all,-ST1000"
    ],
    "cSpell.import": [
        "${userHome}/.config/cspell/cspell.json"
    ],
    "git.openRepositoryInParentFolders": "always",
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": false
    },
    "idf.hasWalkthroughBeenShown": true,
    "rust-analyzer.cargo.features": "all",
    "cmake.showOptionsMovedNotification": false,
    "explorer.confirmDragAndDrop": true,
    "window.titleBarStyle": "native",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "explorer.fileNesting.enabled": false,
    "explorer.incrementalNaming": "smart",
    "git.blame.editorDecoration.enabled": true,
    "docker.extension.enableComposeLanguageServer": false,
    "gitlab.duoCodeSuggestions.enabled": false,
    "gitlab.duoChat.enabled": false,
    "gitlab.duoAgentPlatform.enabled": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "rust-analyzer.check.command": "clippy",
    "workbench.preferredDarkColorTheme": "Visual Studio Dark",
    "workbench.colorCustomizations": {
        "terminal.foreground": "#ffffff",
        "terminal.background": "#000000",
        "terminal.ansiBlack": "#303030",
        "terminal.ansiRed": "#e1321a",
        "terminal.ansiGreen": "#6ab017",
        "terminal.ansiYellow": "#ffc005",
        "terminal.ansiBlue": "#1581ff",
        "terminal.ansiMagenta": "#d500bf",
        "terminal.ansiCyan": "#2cb9f5",
        "terminal.ansiWhite": "#f2f2f2",
        "terminal.ansiBrightBlack": "#787878",
        "terminal.ansiBrightRed": "#ff361e",
        "terminal.ansiBrightGreen": "#7bc91f",
        "terminal.ansiBrightYellow": "#ffd00a",
        "terminal.ansiBrightBlue": "#6eaeff",
        "terminal.ansiBrightMagenta": "#ff39e2",
        "terminal.ansiBrightCyan": "#78cbff",
        "terminal.ansiBrightWhite": "#ffffff"
    }
}
