#!/usr/bin/env python3

import argparse
import subprocess
import os
import json
import sys
import urllib.request
import urllib.error
from enum import StrEnum

class AnthropicModel(StrEnum):
    CLAUDE_OPUS_4_7 = "claude-opus-4-7"
    CLAUDE_OPUS_4_6 = "claude-opus-4-6"
    CLAUDE_SONNET_4_6 = "claude-sonnet-4-6"

def get_api_key():
    """
    Retrieves the API key from git-credential-keepassxc by mimicking the shell pipeline:
    echo 'url=...' | git-credential-keepassxc get | sed
    """
    config_path = os.path.expanduser("~/.config/git-credential-keepassxc")
    input_data = "url=https://api.anthropic.com\n"
    
    process = subprocess.Popen(
        ["git-credential-keepassxc", "--config", config_path, "get"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True
    )
    
    stdout, stderr = process.communicate(input=input_data)
    
    if process.returncode != 0:
        return None

    for line in stdout.splitlines():
        if line.startswith("password="):
            return line.replace("password=", "", 1)


def count_tokens(api_key, message, model: AnthropicModel, system_prompt: str = "", ) -> int:
    """
    Counts tokens for a message using the Anthropic API via urllib.
    """
    url = "https://api.anthropic.com/v1/messages/count_tokens"
    
    # Payload.
    data = {
        "model": str(model),
        "system": system_prompt,
        "messages": [
            {"role": "user", "content": message}
        ]
    }

    headers = {
        "x-api-key": api_key,
        "content-type": "application/json",
        "anthropic-version": "2023-06-01"
    }

    json_data = json.dumps(data).encode("utf-8")
    req = urllib.request.Request(url, data=json_data, headers=headers, method="POST")
    
    try:
        with urllib.request.urlopen(req) as response:
            res_body = response.read().decode("utf-8")
            return json.loads(res_body)['input_tokens']
    except urllib.error.HTTPError as e:
        # Handle API errors (e.g., 401 Unauthorized, 400 Bad Request)
        error_info = e.read().decode("utf-8")
        raise RuntimeError(f"{error_info} (code: {e.code})") from e

def main():
    parser = argparse.ArgumentParser(
        description="Count tokens for a message using the Anthropic API."
    )
    parser.add_argument(
        "file",
        nargs="*",
        help="Paths to files whose concatenated contents are passed as the message. "
             "If omitted, reads from stdin.",
    )
    parser.add_argument(
        "-m", "--model",
        type=AnthropicModel,
        choices=list(AnthropicModel),
        default=AnthropicModel.CLAUDE_OPUS_4_7,
        help="Anthropic model to use for token counting.",
    )
    args = parser.parse_args()

    if args.file:
        parts = []
        for path in args.file:
            with open(path, "r", encoding="utf-8") as f:
                parts.append(f.read())
        message = "".join(parts)
    else:
        message = sys.stdin.read()

    api_key = get_api_key()
    ret = count_tokens(api_key, message, args.model)
    print(ret)

if __name__ == "__main__":
    main()
